{
  "name": "myanso",
  "productName": "Myanso",
  "version": "0.3.2",
  "description": "Myanso — a Myanmar-aware terminal (Electron + xterm.js).",
  "main": "main.js",
  "author": "saturngod",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "patch-xterm": "node patches/patch-xterm-myanmar.js",
    "postinstall": "electron-rebuild -f -w node-pty && node patches/patch-xterm-myanmar.js",
    "dist": "node patches/patch-xterm-myanmar.js && electron-builder --config electron-builder.yml"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "42.3.3",
    "electron-builder": "^26.5.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
